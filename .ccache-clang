#!/bin/sh
# ccache wrapper for clang — used by iOS/macOS CocoaPods builds.
# Falls back to plain clang if ccache is not installed.
# Uses xcrun to resolve the active Xcode toolchain, avoiding DEVELOPER_DIR/PATH mismatches.
# Install ccache: brew install ccache
CLANG=$(xcrun --find clang 2>/dev/null || echo clang)
if command -v ccache >/dev/null 2>&1; then
  exec ccache "$CLANG" "$@"
else
  exec "$CLANG" "$@"
fi
