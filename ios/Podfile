# Uncomment this line to define a global platform for your project
platform :ios, '18.0'

ios_deployment_target = '18.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  flutter_soloud_build_script = File.expand_path('../.symlinks/plugins/flutter_soloud/ios/build_cmake.sh', __FILE__)
  if File.exist?(flutter_soloud_build_script)
    original_script = File.read(flutter_soloud_build_script)
    patched_script = original_script.gsub(
      "echo \"  Using cmake: $(which cmake)\"\n",
      <<~SCRIPT
        echo "  Using cmake: $(which cmake)"

        # Xcode 26 exports deployment targets for several Apple platforms into
        # script phases. CMake's raw compiler probes choke on that mixed
        # environment, so keep only the iPhone target before configuring.
        unset TVOS_DEPLOYMENT_TARGET
        unset WATCHOS_DEPLOYMENT_TARGET
        unset XROS_DEPLOYMENT_TARGET
        unset DRIVERKIT_DEPLOYMENT_TARGET
        unset MACOSX_DEPLOYMENT_TARGET
        export IPHONEOS_DEPLOYMENT_TARGET="${IPHONEOS_DEPLOYMENT_TARGET:-#{ios_deployment_target}}"
      SCRIPT
    ).gsub(
      '-DCMAKE_OSX_DEPLOYMENT_TARGET="13.0" \\',
      "-DCMAKE_OSX_DEPLOYMENT_TARGET=\"${IPHONEOS_DEPLOYMENT_TARGET:-#{ios_deployment_target}}\" \\"
    )
    if patched_script != original_script
      File.write(flutter_soloud_build_script, patched_script)
    end
  end

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    # Route C/C++ compilation through ccache for faster incremental pod builds.
    # The wrapper scripts fall back to plain clang if ccache is not installed.
    # To enable: brew install ccache
    target.build_configurations.each do |config|
      ccache_clang = File.expand_path('../.ccache-clang', __FILE__)
      ccache_clangpp = File.expand_path('../.ccache-clang++', __FILE__)
      config.build_settings['CC'] = ccache_clang
      config.build_settings['CXX'] = ccache_clangpp
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = ios_deployment_target
      # Enable only the permissions the app actually uses.
      # permission_handler requires explicit opt-in at compile time — without this
      # the native code is stripped and iOS never shows the permission dialog.
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)']
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] << 'PERMISSION_MICROPHONE=1'
    end
  end
end
