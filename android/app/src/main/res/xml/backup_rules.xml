<?xml version="1.0" encoding="utf-8"?>
<!--
  Android Auto Backup rules (API 23–30).
  Excludes all app databases and exported backup files from Google Backup.
  https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <!-- Exclude all SQLite databases -->
    <exclude domain="database" path="." />
    <!-- Exclude shared prefs (may contain sensitive flags) -->
    <exclude domain="sharedpref" path="." />
    <!-- Exclude exported .prism backup files in external storage -->
    <exclude domain="external" path="." />
</full-backup-content>
