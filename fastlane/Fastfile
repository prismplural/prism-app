default_platform(:ios)

# Shared App Store Connect API key config
# Requires env vars: ASC_KEY_ID, ASC_ISSUER_ID, ASC_KEY_FILEPATH
def asc_api_key
  params = {
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
  }
  params[:key_filepath] = ENV["ASC_KEY_FILEPATH"] if ENV["ASC_KEY_FILEPATH"]
  app_store_connect_api_key(**params)
end

# Build the --dart-define flag string that bakes the beta relay registration
# token and BuildInfo fields into the binary — matches app/build.sh's
# compute_build_info. The token is read from .env.testflight at the monorepo
# root (gitignored) and is required for internal/TestFlight lanes so beta
# testers don't have to type it by hand.
def build_info_defines
  env_file = File.expand_path("../../.env.testflight", __dir__)
  UI.user_error!(".env.testflight not found at #{env_file}") unless File.exist?(env_file)
  File.foreach(env_file) do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#")
    k, v = line.split("=", 2)
    ENV[k] ||= v if k && v
  end
  token = ENV["PRISM_BETA_REGISTRATION_TOKEN"]
  UI.user_error!("PRISM_BETA_REGISTRATION_TOKEN not set in #{env_file}") if token.nil? || token.empty?

  app_version = File.read("../pubspec.yaml").match(/^version:\s*(\S+)/)&.captures&.first || "unknown"
  git_rev = `git rev-parse --short HEAD`.strip
  git_describe = `git describe --always --dirty`.strip
  git_branch = `git rev-parse --abbrev-ref HEAD`.strip
  built_at = Time.now.utc.strftime("%Y-%m-%dT%H:%M:%SZ")

  [
    "--dart-define=APP_VERSION=#{app_version}",
    "--dart-define=GIT_REV=#{git_rev}",
    "--dart-define=GIT_DESCRIBE=#{git_describe}",
    "--dart-define=GIT_BRANCH=#{git_branch}",
    "--dart-define=BUILT_AT=#{built_at}",
    "--dart-define=PRISM_BETA_REGISTRATION_TOKEN=#{token}",
  ].join(" ")
end

platform :ios do
  desc "Build and upload to TestFlight internal testing"
  lane :internal do
    defines = build_info_defines
    sh("cd .. && flutter build ipa --release #{defines}")

    ipa_path = Dir[File.expand_path("../build/ios/ipa/*.ipa", __dir__)].first
    UI.user_error!("No IPA found in build/ios/ipa/") unless ipa_path

    upload_to_testflight(
      api_key: asc_api_key,
      ipa: ipa_path,
      distribute_external: false,
      notify_external_testers: false,
      skip_waiting_for_build_processing: true,
    )
  end
end

platform :mac do
  desc "Build and upload to TestFlight internal testing"
  lane :internal do
    defines = build_info_defines

    # flutter build writes dart-defines into macos/Flutter/ephemeral/Flutter-Generated.xcconfig
    # so the subsequent xcodebuild archive picks them up without re-specifying them.
    # Unset bundler env vars fastlane injects — they break CocoaPods when
    # flutter invokes pod install with the wrong Ruby gem environment.
    sh("cd .. && env -u BUNDLE_GEMFILE -u BUNDLE_PATH -u BUNDLE_BIN_PATH -u RUBYOPT -u GEM_HOME -u GEM_PATH PATH=\"/opt/homebrew/bin:$PATH\" flutter build macos --release #{defines}")

    build_mac_app(
      workspace: "macos/Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      export_options: File.expand_path("macos_export_options.plist", __dir__),
      output_directory: File.expand_path("../build/macos/export", __dir__),
      skip_package_pkg: false,
      xcargs: "-allowProvisioningUpdates",
    )

    pkg_path = Dir[File.expand_path("../build/macos/export/*.pkg", __dir__)].first
    UI.user_error!("No pkg found in build/macos/export/") unless pkg_path

    upload_to_testflight(
      api_key: asc_api_key,
      pkg: pkg_path,
      skip_waiting_for_build_processing: true,
    )
  end
end

platform :android do
  desc "Build and upload to Play Store internal testing track"
  lane :internal do
    defines = build_info_defines
    sh("cd .. && flutter build appbundle --release #{defines}")

    upload_to_play_store(
      track: "internal",
      aab: File.expand_path("../build/app/outputs/bundle/release/app-release.aab", __dir__),
      json_key: ENV["PLAY_STORE_JSON_KEY"],
      package_name: "com.prismplural.prism",
      release_status: "draft",
    )
  end
end
